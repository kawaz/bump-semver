/// bump-semver Taskfile (pkfire).
///
/// VCS 抽象 / 翻訳ペア / migrate / semver gate は [kawaz/pkf-tasks](https://github.com/kawaz/pkf-tasks) 由来。
/// 本ファイルは Go 系の lint/test/build + bump-semver 固有の release flow だけ持つ。
amends "package://pkg.pkl-lang.org/github.com/mizchi/pkfire/pkfire@0.10.0#/Taskfile.pkl"

import "package://pkg.pkl-lang.org/github.com/kawaz/pkf-tasks/pkf-tasks@2.3.1#/all.pkl" as kawaz

// ---------- shared ----------

local goSources: Listing<String> = new {
  "src/**/*.go"
  "go.mod"
  "go.sum"
}

// ---------- atomic (lint / test / build) ----------

local lintGo: Task = new {
  name = "lint:go"
  description = "gofmt + go vet"
  visibility = "internal"
  inputs = goSources
  cmd =
    """
    gofmt -w . >/dev/null
    go vet ./...
    """
}

// pkf-tasks v2.0.0 で library export から外れたので inline (DR-0008 of pkf-tasks)
local lintPkl: Task = new {
  name = "lint:pkl"
  description = "pkl format -w"
  visibility = "internal"
  inputs {
    "**/*.pkl"
    "**/PklProject"
    "**/PklProject.deps.json"
  }
  cmd =
    """
    set -euo pipefail
    pkl format -w . >/dev/null
    """
}

local lint: Task = new {
  name = "lint"
  description = "lint:go + lint:pkl"
  cache = false
  deps { lintGo; lintPkl }
  // cmd 省略 = deps-only umbrella (pkfire 0.8+)
}

local test: Task = new {
  name = "test"
  description = "go test"
  inputs = goSources
  deps { lint }
  cmd = "go test ./..."
}

local build: Task = new {
  name = "build"
  description = "build (host target)"
  inputs {
    ...goSources
    "VERSION"
  }
  outputs { "bin/bump-semver" }
  deps { lint }
  cmd =
    #"""
    go build -buildvcs=false -trimpath \
      -ldflags "-s -w -X main.version=v$(cat VERSION)" \
      -o bin/bump-semver ./src
    """#
}

local ci: Task = new {
  name = "ci"
  description = "lint + test + build"
  cache = false
  deps { lint; test; build }
  // cmd 省略 = deps-only umbrella (pkfire 0.8+)
}

// ---------- gates (push 内部、利用者が直接叩くことほぼなし) ----------

// main@origin と比較、src/ 変更があれば VERSION bump 必須
local checkVersionBumped: Task =
  (kawaz.semver.checkBumped) {
    compareRefCmd = "echo main@origin"
    triggerPaths = List("src/")
    versionFiles = List("VERSION")
    taskName = "semver:check-version-bumped"
  }.check

// latest v* tag と比較 (release 前の local 確認用、push deps には含めない)
local checkAgainstLatestRelease: Task =
  (kawaz.semver.checkBumped) {
    compareRefCmd = "git tag -l 'v*' --sort=-v:refname | head -1"
    triggerPaths = List("src/")
    versionFiles = List("VERSION")
    taskName = "semver:check-against-latest-release"
    needsFetchTags = true
  }.check

// ---------- release flow ----------

local bumpVersion: Task = new {
  name = "bump-version"
  description = "bump version file(s) for Release"
  cache = false
  deps { kawaz.vcs.ensureClean }
  params {
    new Param {
      name = "level"
      type = "enum"
      choices { "patch"; "minor"; "major" }
      default = "patch"
      description = "semver bump level"
    }
  }
  cmd =
    #"""
    new_version=$(bump-semver "$LEVEL" VERSION --write --no-hint) \
      && jj commit -m "Release v${new_version}"
    """#
}

local push: Task = (kawaz.vcs.push) {
  name = "push"
  description = "push with some checks"
  deps {
    ci
    kawaz.docs.checkTranslations
    checkVersionBumped
    kawaz.migrate.checkPkfTasks
    kawaz.migrate.checkPkfire
  }
}

// ---------- main entries (利用者が直接叩く、宣言順 = 利用頻度の高い順) ----------

// pkf run -- args で default の $@ に args が流れる (pkfire 0.7.0+)
// quiet = true (0.8+) で `[pkf] default: ...` log header を抑制、bin 出力を綺麗に
local default: Task = new {
  name = "default"
  description = "default is run"
  cache = false
  deps { build }
  acceptsArgs = true
  quiet = true
  cmd = #"./bin/bump-semver "$@""#
}

// pkf list の unsorted 版 (declaration 順表示、利用頻度の高い順)
// quiet = true (0.8+) で pkf list 出力を綺麗に
local list: Task = new {
  name = "list"
  description = "list recipes (order matters)"
  cache = false
  quiet = true
  cmd = "pkf list --unsorted"
}

// ---------- task registry (宣言順が pkf list --unsorted の表示順) ----------

tasks {
  default
  list
  test
  push
  bumpVersion
  ci
  build
  lint
  lintGo
  lintPkl
  // push 内部 gate (visibility は pkf-tasks 側で設定済 or 本リポ local の internal 設定)
  ...kawaz.vcs.allTasks
  ...kawaz.docs.allTasks
  checkVersionBumped
  checkAgainstLatestRelease
  kawaz.semver.compare
  ...kawaz.migrate.allTasks
}
