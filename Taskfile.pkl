/// bump-semver Taskfile (pkfire PoC).
///
/// justfile と並走 (pkf を主、just はロールバック先)。
/// レシピ構造は justfile と等価。pkfire の旨味:
///   - lint/test/build は `inputs` で incremental cache
///   - push の deps が DAG で並列実行
///   - typed Task 参照で deps タイポは Pkl 評価時に検出
amends "package://pkg.pkl-lang.org/github.com/mizchi/pkfire/pkfire@0.3.0#/Taskfile.pkl"

local sources: Listing<String> = new {
  "src/**/*.go"
  "go.mod"
  "go.sum"
}

local lint: Task = new {
  name = "lint"
  description = "gofmt + go vet + just --fmt --check"
  cmd = """
    gofmt -w .
    go vet ./...
    just --fmt --check --unstable
    """
  inputs {
    ...sources
    "justfile"
  }
}

local test: Task = new {
  name = "test"
  description = "go test"
  cmd = "go test ./..."
  inputs = sources
  deps { lint }
}

local build: Task = new {
  name = "build"
  description = "release build (host target)"
  cmd = #"""
    go build -buildvcs=false -trimpath \
      -ldflags "-s -w -X main.version=v$(cat VERSION)" \
      -o bin/bump-semver ./src
    """#
  inputs {
    ...sources
    "VERSION"
  }
  outputs { "bin/bump-semver" }
  deps { lint }
}

local ci: Task = new {
  name = "ci"
  description = "lint + test + build"
  cmd = "echo ci ok"
  cache = false
  deps { lint; test; build }
}

local ensureClean: Task = new {
  name = "ensure-clean"
  description = "working copy is clean (jj or git)"
  cache = false
  cmd = """
    if [ -d .jj ]; then
      [ "$(jj log -r @ --no-graph -T 'empty')" = "true" ]
    elif [ -d .git ]; then
      [ -z "$(git status --porcelain)" ]
    fi
    """
  deps { lint }
}

/// 翻訳ペア。`path` は実ファイルパス (`docs/DESIGN` → `docs/DESIGN.md`)、
/// `key` はタスク名の一部 (pkfire は `/` を許容しないので `-` 区切り)。
local class TranslationPair {
  path: String
  fixed key: String = path.replaceAll("/", "-")
}

/// 翻訳ペア NAME-ja.md / NAME.md の存在 + 相互リンク + timestamp 順序確認。
/// -ja.md 不在ならスキップ (justfile の `?` sigil と等価)。
local function checkTranslation(p: TranslationPair): Task = new {
  name = "check-translation:\(p.key)"
  description = "verify translation pair \(p.path).md / \(p.path)-ja.md"
  cache = false
  cmd = """
    if [ ! -f \(p.path)-ja.md ]; then exit 0; fi
    test -f \(p.path).md
    base=$(basename \(p.path))
    head -5 \(p.path)-ja.md | grep -qF "> [English](./${base}.md) | 日本語"
    head -5 \(p.path).md    | grep -qF "> English | [日本語](./${base}-ja.md)"
    file_ts() {
      if [ -d .jj ]; then
        jj log --no-graph -T 'committer.timestamp().format("%s")' -r "latest(::@ & files('$1'))" 2>/dev/null || echo 0
      elif [ -d .git ]; then
        git log -1 --format=%ct -- "$1" 2>/dev/null || echo 0
      else
        echo 0
      fi
    }
    test "$(file_ts \(p.path)-ja.md)" -le "$(file_ts \(p.path).md)"
    """
}

local translationPairs: Listing<TranslationPair> = new {
  new { path = "README" }
  new { path = "docs/DESIGN" }
  new { path = "docs/MANUAL" }
}

local checkTranslationTasks: Listing<Task> = new {
  for (p in translationPairs) {
    checkTranslation(p)
  }
}

local checkTranslations: Task = new {
  name = "check-translations"
  description = "verify README / docs/DESIGN / docs/MANUAL translation pairs"
  cmd = "echo check-translations ok"
  cache = false
  deps = checkTranslationTasks
}

local checkVersionBumped: Task = new {
  name = "check-version-bumped"
  description = "VERSION bumped from origin/main when src/ changed"
  cache = false
  cmd = """
    if [ -d .jj ]; then
      diff_out=$(jj diff -r 'main@origin..@' --summary -- src/) || { echo 'ERROR: jj diff failed (main@origin not tracked? run jj git fetch first)' >&2; exit 1; }
      [ -z "$diff_out" ] && exit 0
    elif [ -d .git ]; then
      git diff --quiet origin/main -- src/ && exit 0
    fi
    bump-semver compare gt VERSION vcs:origin/main --no-hint && exit 0
    echo 'ERROR: code changed but VERSION not bumped; run "pkf run bump-version:patch"' >&2
    exit 1
    """
}

local push: Task = new {
  name = "push"
  description = "jj bookmark main → push (release.yml が VERSION 変更を検出して tag + Release)"
  cache = false
  cmd = """
    jj bookmark set main -r @-
    jj git push --bookmark main
    """
  deps { ensureClean; test; checkTranslations; checkVersionBumped }
}

/// VERSION bump + Release commit。just の `bump-version bump="patch"` 引数を
/// pkfire の name-suffix で表現 (bump-version:patch / :minor / :major)。
local function bumpVersionTask(level: String): Task = new {
  name = "bump-version:\(level)"
  description = "VERSION \(level) bump + Release commit"
  cache = false
  cmd = #"""
    new_version=$(bump-semver \#(level) VERSION --write --no-hint) \
      && jj commit -m "Release v${new_version}"
    """#
  deps { ensureClean }
}

local bumpLevels: Listing<String> = new {
  "patch"
  "minor"
  "major"
}

local bumpVersionTasks: Listing<Task> = new {
  for (level in bumpLevels) {
    bumpVersionTask(level)
  }
}

tasks {
  lint
  test
  build
  ci
  ensureClean
  ...checkTranslationTasks
  checkTranslations
  checkVersionBumped
  push
  ...bumpVersionTasks
}
