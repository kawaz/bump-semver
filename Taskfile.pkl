/// bump-semver Taskfile (pkfire).
///
/// 設計方針: ゴール起点の DAG。VCS 抽象と翻訳ペア検証は
/// [kawaz/pkf-tasks](https://github.com/kawaz/pkf-tasks) に集約し、
/// 本ファイルは Go 系の lint/test/build と bump-semver 固有の
/// release flow だけ持つ。
///
///   User-facing goals    | 内部 gate
///   ---------------------|----------------
///   default (= list)     | lint
///   lint / test / build  | kawaz.vcs.ensureClean (kawaz/pkf-tasks)
///   ci                   | kawaz.docs.checkTranslations (kawaz/pkf-tasks)
///   bump-version         | checkVersionBumped (本リポ固有)
///   run                  |
///   push                 |
///
/// pkfire の旨味:
///   - inputs ベースで lint/test/build は incremental cache
///   - typed Task 参照 + Param で deps / 引数のタイポは Pkl 評価時に検出
///   - DAG 並列実行 (`pkf graph --format mermaid`)
///   - 副作用タスクは cache = false で常時実行
///
/// justfile は **比較用に残してあるだけ**。CI / ローカルの主運用は
/// 本 Taskfile.pkl + pkf (kawaz/pkf-tasks 経由)。justfile への依存は
/// Taskfile.pkl 内には一切無い (lint で `just --fmt` を呼んだりしない)。
amends "package://pkg.pkl-lang.org/github.com/mizchi/pkfire/pkfire@0.4.0#/Taskfile.pkl"

import "package://pkg.pkl-lang.org/github.com/kawaz/pkf-tasks/pkf-tasks@0.0.11#/all.pkl" as kawaz

// =============================================================================
// Shared file sets
// =============================================================================

local goSources: Listing<String> = new {
  "src/**/*.go"
  "go.mod"
  "go.sum"
}

// =============================================================================
// Atomic tasks
// =============================================================================

// lint:go — Go 系の lint。本リポ固有 (将来 kawaz/* に Go リポが増えれば
// pkf-tasks/lint/go.pkl に外出しする候補)。
local lintGo: Task = new {
  name = "lint:go"
  description = "gofmt -w / go vet"
  inputs = goSources
  cmd =
    """
    gofmt -w .
    go vet ./...
    """
}

// lint — umbrella。言語横断の lint:pkl (pkf-tasks 由来) と本リポの
// lint:go をまとめる。`pkf list` でソートしたとき lint / lint:go /
// lint:pkl が隣接して読みやすい。
local lint: Task = new {
  name = "lint"
  description = "all lints (lint:go + lint:pkl)"
  cache = false
  deps { lintGo; kawaz.lint.pkl }
  cmd = "echo lint ok"
}

local test: Task = new {
  name = "test"
  description = "go test ./..."
  inputs = goSources
  deps { lint }
  cmd = "go test ./..."
}

local build: Task = new {
  name = "build"
  description = "release binary (host target) -> bin/bump-semver"
  inputs {
    ...goSources
    "VERSION"
  }
  outputs { "bin/bump-semver" }
  deps { lint }
  cmd =
    #"""
    go build -buildvcs=false -trimpath \
      -ldflags "-s -w -X main.version=v$(cat VERSION)" \
      -o bin/bump-semver ./src
    """#
}

// =============================================================================
// Umbrella
// =============================================================================

local ci: Task = new {
  name = "ci"
  description = "lint + test + build (DAG 並列)"
  cache = false
  deps { lint; test; build }
  cmd = "echo ci ok"
}

// =============================================================================
// Run (variadic args passthrough; `just run *ARGS` の代替)
//
// pkfire 0.4.0+ の acceptsArgs = true で `--` 後の任意引数を $@ で受ける。
//   pkf run run -- patch Cargo.toml --write
//   pkf run run -- compare gt VERSION 1.0.0
// =============================================================================

local run: Task = new {
  name = "run"
  description = "Run built bin/bump-semver with forwarded args"
  cache = false
  deps { build }
  acceptsArgs = true
  cmd = #"./bin/bump-semver "$@""#
}

// =============================================================================
// Project-specific gates (semver:check-* は kawaz/pkf-tasks 0.0.7+ semver group)
// =============================================================================

// push 前ガード: main@origin と比較して src/ 変更があれば VERSION bump 必須。
local checkVersionBumped: Task =
  (kawaz.semver.checkBumped) {
    compareRefCmd = "echo main@origin"
    triggerPaths = List("src/")
    versionFiles = List("VERSION")
    taskName = "semver:check-version-bumped"
  }.check

// CI release 向け補助ガード: 最新 v* tag と比較して src/ 変更があれば
// VERSION bump 必須。release tag を作る前に local で確認する用途。
// release.yml 自体は tag push で trigger されるため CI に組み込んではいない
// (tag 作成時点で既に bump 済が前提)。
//
// needsFetchTags = true: tag 系の compareRef を使うので vcs:fetch-tags を
// deps に挟む (pkf-tasks 0.0.9+、DR-0006)。これにより jj 環境で `git fetch
// --tags origin` 後に `jj git import` が必要になる症状を吸収する。
local checkAgainstLatestRelease: Task =
  (kawaz.semver.checkBumped) {
    compareRefCmd = "git tag -l 'v*' --sort=-v:refname | head -1"
    triggerPaths = List("src/")
    versionFiles = List("VERSION")
    taskName = "semver:check-against-latest-release"
    needsFetchTags = true
  }.check

// =============================================================================
// Bump version (typed Param: level=patch|minor|major)
// =============================================================================

local bumpVersion: Task = new {
  name = "bump-version"
  description = "VERSION bump + jj commit (level=patch|minor|major)"
  cache = false
  deps { kawaz.vcs.ensureClean }
  params {
    new Param {
      name = "level"
      type = "enum"
      choices { "patch"; "minor"; "major" }
      default = "patch"
      description = "semver bump level"
    }
  }
  cmd =
    #"""
    new_version=$(bump-semver "$LEVEL" VERSION --write --no-hint) \
      && jj commit -m "Release v${new_version}"
    """#
}

// =============================================================================
// Push (top-level goal)
//
// kawaz.vcs.push を base にして deps だけ拡張 (cmd / env は継承)。
// 全 gate (ci + kawaz.docs.checkTranslations + checkVersionBumped) 通過後に
// main を進めて push。release.yml が VERSION 変更を検出した時のみ
// tag + GitHub Release を作る。
// =============================================================================

local push: Task = (kawaz.vcs.push) {
  name = "push"
  description = "all gates → jj bookmark main → jj git push (extends kawaz.vcs.push)"
  // migrate:check-pkf-tasks-current を deps に入れて push 時に pkf-tasks 古さも検知
  deps { ci; kawaz.docs.checkTranslations; checkVersionBumped; kawaz.migrate.check }
}

// =============================================================================
// Default
// =============================================================================

local default: Task = new {
  name = "default"
  description = "list available tasks"
  cache = false
  cmd = "pkf list"
}

// =============================================================================
// Task registry
// =============================================================================

tasks {
  default
  // lint umbrella + children (lint:go ローカル / lint:pkl は pkf-tasks 由来)
  lint
  lintGo
  kawaz.lint.pkl
  // atomic (test / build は lint umbrella を依存)
  test
  build
  run
  // ci umbrella
  ci
  // gates (kawaz.vcs.ensureClean / kawaz.docs.checkTranslations は pkf-tasks 由来)
  ...kawaz.vcs.allTasks
  ...kawaz.docs.allTasks
  // semver gates (pkf-tasks/semver/check-bumped を 2 instance 化)
  checkVersionBumped
  checkAgainstLatestRelease
  // semver:compare 汎用 task (pkf-tasks 0.0.8 実験的、ad-hoc CLI 用)
  kawaz.semver.compare
  // migrate group (pkf-tasks 0.0.11: 利用側の pkf-tasks 追従 gate + action)
  ...kawaz.migrate.allTasks
  // release flow
  bumpVersion
  push
}
