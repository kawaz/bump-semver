/// bump-semver Taskfile (pkfire).
///
/// 設計方針: ゴール起点の DAG。VCS 抽象と翻訳ペア検証は
/// [kawaz/pkf-tasks](https://github.com/kawaz/pkf-tasks) に集約し、
/// 本ファイルは Go 系の lint/test/build と bump-semver 固有の
/// release flow だけ持つ。
///
///   User-facing goals    | 内部 gate
///   ---------------------|----------------
///   default (= list)     | lint
///   lint / test / build  | vcs.ensureClean (kawaz/pkf-tasks)
///   ci                   | docs.checkTranslations (kawaz/pkf-tasks)
///   bump-version         | checkVersionBumped (本リポ固有)
///   run                  |
///   push                 |
///
/// pkfire の旨味:
///   - inputs ベースで lint/test/build は incremental cache
///   - typed Task 参照 + Param で deps / 引数のタイポは Pkl 評価時に検出
///   - DAG 並列実行 (`pkf graph --format mermaid`)
///   - 副作用タスクは cache = false で常時実行
///
/// justfile も並走中 (CI が依然 `just ci` を呼ぶため、pkfire 完全
/// 移行は別フェーズ)。比較用に残してある。
amends "package://pkg.pkl-lang.org/github.com/mizchi/pkfire/pkfire@0.4.0#/Taskfile.pkl"

import "package://pkg.pkl-lang.org/github.com/kawaz/pkf-tasks/pkf-tasks@0.0.5#/vcs/auto.pkl" as vcs
import "package://pkg.pkl-lang.org/github.com/kawaz/pkf-tasks/pkf-tasks@0.0.5#/docs/translations.pkl" as docs

// =============================================================================
// Shared file sets
// =============================================================================

local goSources: Listing<String> = new {
  "src/**/*.go"
  "go.mod"
  "go.sum"
}

// =============================================================================
// Atomic tasks
// =============================================================================

local lint: Task = new {
  name = "lint"
  description = "gofmt -w / go vet / just --fmt --check"
  inputs {
    ...goSources
    "justfile"
    "Taskfile.pkl"
  }
  cmd = """
    gofmt -w .
    go vet ./...
    just --fmt --check --unstable
    """
}

local test: Task = new {
  name = "test"
  description = "go test ./..."
  inputs = goSources
  deps { lint }
  cmd = "go test ./..."
}

local build: Task = new {
  name = "build"
  description = "release binary (host target) -> bin/bump-semver"
  inputs {
    ...goSources
    "VERSION"
  }
  outputs { "bin/bump-semver" }
  deps { lint }
  cmd = #"""
    go build -buildvcs=false -trimpath \
      -ldflags "-s -w -X main.version=v$(cat VERSION)" \
      -o bin/bump-semver ./src
    """#
}

// =============================================================================
// Umbrella
// =============================================================================

local ci: Task = new {
  name = "ci"
  description = "lint + test + build (DAG 並列)"
  cache = false
  deps { lint; test; build }
  cmd = "echo ci ok"
}

// =============================================================================
// Run (variadic args passthrough; `just run *ARGS` の代替)
//
// pkfire 0.4.0+ の acceptsArgs = true で `--` 後の任意引数を $@ で受ける。
//   pkf run run -- patch Cargo.toml --write
//   pkf run run -- compare gt VERSION 1.0.0
// =============================================================================

local run: Task = new {
  name = "run"
  description = "Run built bin/bump-semver with forwarded args"
  cache = false
  deps { build }
  acceptsArgs = true
  cmd = #"./bin/bump-semver "$@""#
}

// =============================================================================
// Project-specific gate
// =============================================================================

local checkVersionBumped: Task = new {
  name = "check-version-bumped"
  description = "VERSION bumped vs origin/main when src/ changed"
  cache = false
  deps { vcs.ensureClean }
  cmd = """
    if jj root >/dev/null 2>&1; then
      diff_out=$(jj diff -r 'main@origin..@' --summary -- src/) \\
        || { echo 'ERROR: jj diff failed (main@origin not tracked? run jj git fetch first)' >&2; exit 1; }
      [ -z "$diff_out" ] && exit 0
    elif git rev-parse --git-dir >/dev/null 2>&1; then
      git diff --quiet origin/main -- src/ && exit 0
    fi
    bump-semver compare gt VERSION vcs:origin/main --no-hint && exit 0
    echo 'ERROR: code changed but VERSION not bumped; run "pkf run bump-version --level=patch"' >&2
    exit 1
    """
}

// =============================================================================
// Bump version (typed Param: level=patch|minor|major)
// =============================================================================

local bumpVersion: Task = new {
  name = "bump-version"
  description = "VERSION bump + jj commit (level=patch|minor|major)"
  cache = false
  deps { vcs.ensureClean }
  params {
    new Param {
      name = "level"
      type = "enum"
      choices { "patch"; "minor"; "major" }
      default = "patch"
      description = "semver bump level"
    }
  }
  cmd = #"""
    new_version=$(bump-semver "$LEVEL" VERSION --write --no-hint) \
      && jj commit -m "Release v${new_version}"
    """#
}

// =============================================================================
// Push (top-level goal)
//
// vcs.push を base にして deps だけ拡張 (cmd / env は継承)。
// 全 gate (ci + docs.checkTranslations + checkVersionBumped) 通過後に
// main を進めて push。release.yml が VERSION 変更を検出した時のみ
// tag + GitHub Release を作る。
// =============================================================================

local push: Task = (vcs.push) {
  name = "push"
  description = "all gates → jj bookmark main → jj git push (extends vcs.push)"
  deps { ci; docs.checkTranslations; checkVersionBumped }
}

// =============================================================================
// Default
// =============================================================================

local default: Task = new {
  name = "default"
  description = "list available tasks"
  cache = false
  cmd = "pkf list"
}

// =============================================================================
// Task registry
// =============================================================================

tasks {
  default
  // atomic
  lint
  test
  build
  run
  // umbrella
  ci
  // gates (vcs.ensureClean / docs.checkTranslations は pkf-tasks 由来)
  ...vcs.allTasks
  ...docs.allTasks
  checkVersionBumped
  // release flow
  bumpVersion
  push
}
