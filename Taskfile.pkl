/// bump-semver Taskfile (pkfire) — translation-check shim only.
///
/// Justfile is the canonical task runner. This file exists solely to host
/// `docs:check-translations` (and its leaves), which currently lives in
/// kawaz/pkf-tasks and has no standalone CLI yet. The Justfile's
/// `check-translations` recipe shells out to `pkf run docs:check-translations`.
///
/// When a standalone CLI for translation-pair checking lands, this file can be
/// removed (and `lint:pkl` requirements with it).
amends "package://pkg.pkl-lang.org/github.com/mizchi/pkfire/pkfire@0.10.0#/Taskfile.pkl"

import "package://pkg.pkl-lang.org/github.com/kawaz/pkf-tasks/pkf-tasks@3.0.3#/all.pkl" as kawaz

tasks {
  ...kawaz.docs.tasks
}
