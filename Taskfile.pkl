/// bump-semver Taskfile (pkfire).
///
/// VCS 抽象 / 翻訳ペア / migrate / semver gate は [kawaz/pkf-tasks](https://github.com/kawaz/pkf-tasks) 由来。
/// 本ファイルは Go 系の lint/test/build + bump-semver 固有の release flow だけ持つ。
amends "package://pkg.pkl-lang.org/github.com/mizchi/pkfire/pkfire@0.10.0#/Taskfile.pkl"

import "package://pkg.pkl-lang.org/github.com/kawaz/pkf-tasks/pkf-tasks@3.0.3#/all.pkl" as kawaz

// ---------- shared ----------

local goSources: Listing<String> = new {
  "src/**/*.go"
  "go.mod"
  "go.sum"
}

// ---------- atomic (lint / test / build) ----------

local lintGo: Task = new {
  name = "lint:go"
  description = "gofmt + go vet"
  visibility = "internal"
  inputs = goSources
  cmd =
    """
    gofmt -w . >/dev/null
    go vet ./...
    """
}

// pkf-tasks v2.0.0 で library export から外れたので inline (DR-0008 of pkf-tasks)
local lintPkl: Task = new {
  name = "lint:pkl"
  description = "pkl format -w"
  visibility = "internal"
  inputs {
    "**/*.pkl"
    "**/PklProject"
    "**/PklProject.deps.json"
  }
  cmd =
    """
    set -euo pipefail
    pkl format -w . >/dev/null
    """
}

local lint: Task = new {
  name = "lint"
  description = "lint:go + lint:pkl"
  cache = false
  deps { lintGo; lintPkl }
}

local test: Task = new {
  name = "test"
  description = "go test"
  inputs = goSources
  deps { lint }
  cmd = "go test ./..."
}

local build: Task = new {
  name = "build"
  description = "build (host target)"
  inputs {
    ...goSources
    "VERSION"
  }
  outputs { "bin/bump-semver" }
  deps { lint }
  cmd =
    #"""
    go build -buildvcs=false -trimpath \
      -ldflags "-s -w -X main.version=v$(cat VERSION)" \
      -o bin/bump-semver ./src
    """#
}

local ci: Task = new {
  name = "ci"
  description = "lint + test + build"
  cache = false
  deps { lint; test; build }
}

// ---------- gates (push 内部、利用者が直接叩くことほぼなし) ----------

// main@origin と比較、src/ 変更があれば VERSION bump 必須
local checkVersionBumped: Task =
  (kawaz.semver.checkBumped) {
    compareRef = "main@origin"
    triggerPaths = List("src/")
    versionFiles = List("VERSION")
    taskName = "semver:check-version-bumped"
  }.check

// latest semver tag と比較 (release 前の local 確認用、push deps には含めない)
local checkAgainstLatestRelease: Task =
  (kawaz.semver.checkBumped) {
    compareRef = "vcs:latest-tag()"
    triggerPaths = List("src/")
    versionFiles = List("VERSION")
    taskName = "semver:check-against-latest-release"
    needsFetchTags = true
  }.check

// v0.16.0 で導入した cmd: input source を使って「VERSION 値 + bin --version 出力」を
// 横断比較。release 前 release commit に bin build 忘れがないか検出する gate。
// (kawaz/pkf-tasks v3.0 で導入された versions module の dogfood)
local versions = (kawaz.semver.versions) {
  versionFiles = List("VERSION")
  cmdSources = List("cmd:./bin/bump-semver --version")
}
local versionDisplay: Task = versions.version
local checkVersionsAligned: Task = versions.checkAligned

// ---------- release flow ----------

// bump-semver 自身の `vcs is clean` をドッグフードしてワーキングツリー dirty チェック。
// pkf-tasks の `vcs.ensureClean` を置き換えることで外部依存削減 + セルフ検証。
// 前提: PATH 上に bump-semver v0.20.0 以降 (= `vcs is clean` サブコマンド対応版)。
local localEnsureClean: Task = new {
  name = "vcs:ensure-clean"
  description = "working copy is clean (dogfood: bump-semver vcs is clean)"
  cache = false
  cmd =
    #"""
    bump-semver vcs is clean || { echo "working tree is dirty" >&2; exit 1; }
    """#
}

local bumpVersion: Task = new {
  name = "bump-version"
  description = "bump version file(s) for Release"
  cache = false
  deps { localEnsureClean }
  params {
    new Param {
      name = "level"
      type = "enum"
      choices { "patch"; "minor"; "major" }
      default = "patch"
      description = "semver bump level"
    }
  }
  cmd =
    #"""
    new_version=$(bump-semver "$LEVEL" VERSION --write --no-hint) \
      && jj commit -m "Release v${new_version}"
    """#
}

// workflowTests を pkf affected --check で検証する gate (pkfire 0.10+)
// Taskfile.pkl の構造変更で affected が想定外になったら CI で検出
local testWorkflow: Task = new {
  name = "test:workflow"
  description = "verify workflowTests match actual affected plan"
  cache = false
  visibility = "internal"
  quiet = true
  cmd = "pkf affected --check"
}

local push: Task = (kawaz.vcs.push) {
  name = "push"
  description = "push with some checks"
  deps {
    ci
    kawaz.docs.checkTranslations
    checkVersionBumped
    kawaz.migrate.checkPkfTasks
    kawaz.migrate.checkPkfire
    testWorkflow
  }
}

// ---------- main entries (利用者が直接叩く、宣言順 = 利用頻度の高い順) ----------

local default: Task = new {
  name = "default"
  description = "default is run"
  cache = false
  deps { build }
  acceptsArgs = true
  quiet = true
  cmd = #"./bin/bump-semver "$@""#
}

local list: Task = new {
  name = "list"
  description = "list recipes (order matters)"
  cache = false
  quiet = true
  cmd = "pkf list --unsorted --color=always"
}

// ---------- workflow tests (pkfire 0.10+、Taskfile 自体の壊れを affected --check で検出) ----------

workflowTests {
  new {
    name = "Go source change triggers full push pipeline"
    changed { "src/main.go" }
    direct { "lint:go"; "build"; "test" }
    tasks {
      "lint:go"
      "lint:pkl"
      "lint"
      "build"
      "test"
      "ci"
      "default"
      "docs:check-translation-commit-lag"
      "docs:check-translation-links"
      "docs:check-translations"
      "migrate:check-pkf-tasks-current"
      "migrate:check-pkfire-current"
      "semver:check-version-bumped"
      "test:workflow"
      "push"
    }
  }
}

// ---------- task registry (宣言順が pkf list --unsorted の表示順) ----------

tasks {
  default
  list
  test
  push
  bumpVersion
  ci
  build
  lint
  lintGo
  lintPkl
  testWorkflow
  // push 内部 gate (visibility は pkf-tasks 側で設定済 or 本リポ local の internal 設定)
  // vcs:ensure-clean は pkf-tasks 版の代わりに localEnsureClean (bump-semver dogfood) を登録、
  // 残り 4 task (commit/push/fetch/fetch-tags) は pkf-tasks をそのまま採用。
  localEnsureClean
  kawaz.vcs.commit
  kawaz.vcs.push
  kawaz.vcs.fetch
  kawaz.vcs.fetchTags
  ...kawaz.docs.tasks
  checkVersionBumped
  checkAgainstLatestRelease
  versionDisplay
  checkVersionsAligned
  kawaz.semver.compare
  ...kawaz.migrate.tasks
}
